{
  "name": "music-downloader",
  "version": "1.0.0",
  "description": "GD Studio Music API — 搜索、试听、下载",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:all": "electron-builder --linux --win --mac"
  },
  "build": {
    "appId": "xyz.gdstudio.music-downloader",
    "productName": "Music Downloader",
    "asar": false,
    "files": [
      "electron/**/*",
      "templates/**/*",
      "static/**/*",
      "webui.py",
      "music_dl.py",
      "requirements.txt"
    ],
    "extraResources": [
      {
        "from": ".venv",
        "to": ".venv"
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Audio",
      "icon": "electron/icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "electron/icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.music",
      "icon": "electron/icon.png",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "不需要麦克风权限"
      }
    }
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  },
  "author": "Tom8266 <tom@example.com>",
  "maintainer": "Tom8266"
}
